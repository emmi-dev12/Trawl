{
  "package": {
    "productName": "Trawl",
    "version": "1.0.0"
  },
  "build": {
    "distDir": "dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "http": {
        "all": true,
        "scope": ["http://127.0.0.1:5555/**"]
      }
    },
    "windows": [
      {
        "title": "Trawl",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "visible": true,
        "fullscreen": false
      }
    ],
    "bundle": {
      "active": true,
      "targets": ["app", "dmg"],
      "identifier": "com.trawl.app",
      "icon": [
        "icons/icon.png"
      ],
      "resources": [],
      "externalBin": [],
      "copyright": "Copyright © 2026 Trawl",
      "category": "Utilities",
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "10.5"
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    }
  }
}
