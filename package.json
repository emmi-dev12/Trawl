{
  "name": "trawl",
  "version": "1.0.0",
  "description": "A fast, no-AI, general-purpose web scraper for macOS",
  "main": "frontend/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run backend\" \"electron .\"",
    "backend": "cd backend && python server.py",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "keywords": ["scraper", "web", "playwright"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.2.1"
  },
  "dependencies": {},
  "build": {
    "appId": "com.trawl.app",
    "productName": "Trawl",
    "files": [
      "frontend/**/*",
      "backend/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities"
    }
  }
}
